{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-plc-practice-2026"
		},
		"LS_AzureSQL_Source_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_AzureSQL_Source'"
		},
		"LS_Snowflake_DWH_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_Snowflake_DWH'"
		},
		"LS_AzureBlob_Staging_sasUri": {
			"type": "secureString",
			"metadata": "Secure string for 'sasUri' of 'LS_AzureBlob_Staging'"
		},
		"LS_AzureSQL_Source_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver-plc-practice-001.database.windows.net"
		},
		"LS_AzureSQL_Source_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().DB_Name}"
		},
		"LS_AzureSQL_Source_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "plcadmin"
		},
		"LS_Snowflake_DWH_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "PLC_DWH"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-plc-practice-2026_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_AzureSQL_Source_password": {
						"value": "[parameters('LS_AzureSQL_Source_password')]"
					},
					"LS_Snowflake_DWH_password": {
						"value": "[parameters('LS_Snowflake_DWH_password')]"
					},
					"LS_AzureBlob_Staging_sasUri": {
						"value": "[parameters('LS_AzureBlob_Staging_sasUri')]"
					},
					"LS_AzureSQL_Source_properties_typeProperties_server": {
						"value": "[parameters('LS_AzureSQL_Source_properties_typeProperties_server')]"
					},
					"LS_AzureSQL_Source_properties_typeProperties_database": {
						"value": "[parameters('LS_AzureSQL_Source_properties_typeProperties_database')]"
					},
					"LS_AzureSQL_Source_properties_typeProperties_userName": {
						"value": "[parameters('LS_AzureSQL_Source_properties_typeProperties_userName')]"
					},
					"LS_Snowflake_DWH_properties_typeProperties_database": {
						"value": "[parameters('LS_Snowflake_DWH_properties_typeProperties_database')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}