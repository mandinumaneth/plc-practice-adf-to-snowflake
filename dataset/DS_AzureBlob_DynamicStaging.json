{
	"name": "DS_AzureBlob_DynamicStaging",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_AzureBlob_Staging",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Param_DB": {
				"type": "string"
			},
			"Param_Schema": {
				"type": "string"
			},
			"Param_Table": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@concat(dataset().Param_Table, '.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat(dataset().Param_DB, '/', dataset().Param_Schema, '/', dataset().Param_Table)",
					"type": "Expression"
				},
				"container": "landing-zone"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}